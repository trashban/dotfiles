{
	"layer": "top",
	"position": "top",

    "modules-left": ["hyprland/workspaces", "tray"],
    "modules-center": ["mpris"],
    "modules-right": ["network", "temperature", "custom/separator", "memory", "custom/separator", "wireplumber", "custom/separator", "clock"],

	"hyprland/workspaces": {
        "format": "{}",
        "sort-by-coordinates": true,
        "all-output": false,
        "active-only": false,
        "sort-by-number": false,
        "on-click": "activate"
    },

	"hyprland/window": {
    	"format": "{initialTitle}",
    	"max-length": 30
    },

    // niri

    "niri/workspaces": {
        // "format": "{icon}",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "VIII",
            "9": "IX",
            "10": "X"
        }
    },

	"niri/window": {
        "format": "{title}",
        "max-length": 30,
        "rewrite": {
            "": "niri"
        }
    },

    // river

    "river/tags": {
        "hide-vacant": true
    },

    "river/window": {
        "max-length": 40,
    },

    // sway

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        // "format": "{icon}",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "VIII",
            "9": "IX",
            "10": "X"
        }
    },

    "sway/window": {
        "format": "{title}",
        "max-length": 30,
        "rewrite": {
            "": "sway"
        }
    },

    "mpris": {
        "format": "{status_icon} {title} - {artist}",
        "title-len": 30,
        "status-icons": {
            "playing": "▶",
            "paused": "⏸"
        }
        // "ignored-players": ["firefox", "firefox-bin"]
    },

    "tray": {
        "icon-size": 18,
        "spacing": 15
    },

    "network": {
        "format-ethernet": "{ipaddr}/{cidr} 󰊗",
        "format-wifi": "{ipaddr}",
        "format-disconnected": "fuck",
        "interval": 10
    },

    "temperature": {
        "hwmon-path": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon1/temp1_input",
		"format": "temp {temperatureC}°C",
		"format-icons":["", ""],
        "critical-threshold": 80,
        
    },

    "disk": {
        "format": "disk {percentage_used}%",
        "interval": 60
    },

    "memory": {
        "format": "ram {used:0.1f}G",
        "interval": 5
    },

    "cpu": {
        "format": "<span color='#b2ccd6'>CPU</span>: {avg_frequency} GHz",
        "interval": 5
    },

    "wireplumber": {
        "format": "vol {volume}%",
        "format-muted": "",
        "format-icons": ["", "", ""]
    },

    "battery": {
        "format": "bat {}%"
    },

    "clock": {
        "format": "{:%d/%m %I:%M %p}",
        "interval": 30,
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-scroll-up": "tz_up",
                    "on-scroll-down": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },

    "custom/separator": {
        "format": ":"
    }
}
